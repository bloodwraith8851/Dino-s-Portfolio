# Supabase (Required for guestbook, polls, telemetry, live chat)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Neon Database (Required for analytics tracking)
NEON_DATABASE_URL=

# Upstash Redis (Required for edge caching & rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin Authentication (Required for accessing terminal 'admin' tools)
JWT_SECRET=
ADMIN_PASSWORD=

# Inngest (Required for background job processing)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Resend (Required for sending email notifications)
RESEND_API_KEY=

# ImageKit (Optional - for image optimization fallback)
VITE_IMAGEKIT_ENDPOINT=

# Web3Forms (Optional - legacy fallback for contact form delivery)
VITE_WEB3FORMS_KEY=

# Sentry (Optional - for client/server error tracking)
VITE_SENTRY_DSN=
SENTRY_DSN=

# GitHub (Optional - for server-cached GitHub stats at /api/github)
# Generate at: https://github.com/settings/tokens (read:public_repo scope)
GITHUB_TOKEN=

# Google AI / Gemini (Required for AI chat at /api/ai/chat)
# Generate at: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=

# CORS (Production - restrict API access to your domain)
# Set to your Vercel deployment URL, e.g. https://dino-s-portfolio.vercel.app
ALLOWED_ORIGIN=

# Resume PDF URL (Required for /api/resume/download)
# Path relative to public/ (e.g. /Rakesh_Sarkar_Resume.pdf) or a full external URL
RESUME_PDF_URL=/Rakesh_Sarkar_Resume.pdf
